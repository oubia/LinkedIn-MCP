# LinkedIn API Configuration
# Copy this file to .env and fill in your actual values

# LinkedIn OAuth Credentials
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/auth/linkedin/callback

# LinkedIn API Scopes
LINKEDIN_SCOPE=r_liteprofile,r_emailaddress,w_member_social,r_organization_social

# Server Configuration
PORT=8080
HOST=localhost
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/linkedin_mcp.log

# Security
JWT_SECRET_KEY=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Database (optional - for storing application history)
DATABASE_URL=sqlite:///linkedin_mcp.db

# Rate Limiting
REQUESTS_PER_MINUTE=60
REQUESTS_PER_HOUR=500