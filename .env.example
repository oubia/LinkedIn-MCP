# LinkedIn credentials
LINKEDIN_USERNAME=your_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
# Optional: provide an authenticated session cookie to bypass MFA (li_at)
# LINKEDIN_SESSION_COOKIE=

# Local profile and mapping files
USER_PROFILE_PATH=data/user_profile.json
FORM_MAPPING_PATH=data/form_mapping.json
OUTPUT_DIR=output

# Playwright settings
PLAYWRIGHT_HEADLESS=true
# PLAYWRIGHT_SLOWMO=100
# LINKEDIN_STORAGE_STATE_PATH=data/linkedin.storage.json

# Generation provider configuration
GENERATION_PROVIDER=openai
GENERATION_MODEL=gpt-4o
GENERATION_API_KEY=your_openai_api_key
# GENERATION_BASE_URL=
# OPENAI_ORGANIZATION=
# GENERATION_TEMPERATURE=0.4
# GENERATION_MAX_TOKENS=2000

# For Azure OpenAI deployments
# GENERATION_PROVIDER=azure-openai
# GENERATION_BASE_URL=https://<resource-name>.openai.azure.com
# GENERATION_MODEL=<deployment-name>
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# For Anthropic Claude models
# GENERATION_PROVIDER=anthropic
# GENERATION_MODEL=claude-3-opus-20240229
# GENERATION_API_KEY=your_anthropic_api_key
